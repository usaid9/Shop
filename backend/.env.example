# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/premium_store

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── JazzCash ─────────────────────────────────────────────────
# Get these from https://sandbox.jazzcash.com.pk (sandbox)
# or https://payments.jazzcash.com.pk (production)
JAZZCASH_MERCHANT_ID=your_merchant_id
JAZZCASH_PASSWORD=your_jazzcash_password
JAZZCASH_INTEGRITY_SALT=your_integrity_salt
JAZZCASH_RETURN_URL=http://localhost:3000/payment/callback
JAZZCASH_ENV=sandbox          # sandbox | production

# ── Email (Nodemailer / Gmail) ────────────────────────────────
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password   # Gmail App Password

# ── Frontend Origin ───────────────────────────────────────────
CLIENT_URL=http://localhost:3000
